function PreviousPage()
{
if(CurrentPage>1)
{
CurrentPage--;
GetArticle(CurrentColumnType,CurrentPage,"Desc");
}
else
{
CurrentPage=CurrentPageCount;
GetArticle(CurrentColumnType,CurrentPage,"Desc");
