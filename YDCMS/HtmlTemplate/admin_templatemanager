<script>
var monacoEditor;
var LockerText;
GetHtmlTemplate();
SelectLanguage("");
function DelectTemplate(HtmlFileName)
{
                var PostMsg = new FormData();
                PostMsg.append('type', "DelectHtmlTemplate");
                PostMsg.append('HtmlFileName',document.getElementById("HtmlFileName").value);
                $.ajax({
                    type: "Post",
                    async: "false",
                    dataType: "text",
                    url: "(@_WebRequestUrl_@)",
                    data: PostMsg,
                    processData: false,
                    contentType: false,
                    success: function (data) {
                    document.getElementById("HtmlFileName").value="";
                    SetHeadCode="";
                    document.getElementById("HeadCode").value="";
                    monacoEditor.setValue("");
                    GetHtmlTemplate();
                    }
                });
}
function GetHtmlTemplate()
{
$.ajax({
                    type: "Get",
                    async: "false",
                    dataType: "Json",
                    url: "(@_WebRequestUrl_@)",
                    data: "type=GetHtmlTemplate",
                    success: function (data) {

                     if (data.length > 0) {
                            var richtext = "";
                            for (i = 0; i < data.length; i++) {
                                richtext = richtext + "<tr>";
                                richtext = richtext + "<td>" + data[i].HtmlFileName + "</td>";
                                richtext = richtext + "<td>" + data[i].HtmlAction + "</td>";
                                richtext = richtext + "<td>" + data[i].LockerType + "</td>";
                                richtext = richtext + "<td>" +  "<textarea id='" + i + "HeadCode" + "'>"+data[i].HeadCode+"</textarea></td>";
                                richtext = richtext + "<td>" + data[i].CallCount + "</td>";
                                richtext = richtext + "<td>" + "<textarea id='" + i + "CodeText" + "'>"+window.btoa(toUtf8(data[i].CodeText))+"</textarea></td>";
                                richtext = richtext + "<td>" + "<a  class='btn btn-info' onclick='CreatTemplate("+i+",\""+data[i].HtmlFileName+"\")'>修改</a><a  class='btn btn-danger' onclick='DelectTemplate(\""+data[i].HtmlFileName+"\")'>删除</a>" + "</td>";
                                richtext = richtext + "</tr>";
                            }
                            document.getElementById("FileList").innerHTML = richtext;
                        }
                           
                   }
});
}
var SetHeadCode;
function CreatTemplate(i,HtmlFileName)
{
  document.getElementById("HtmlFileName").value=HtmlFileName;
  document.getElementById("HeadCode").value= document.getElementById(i+"HeadCode").innerHTML;
  SetHeadCode=document.getElementById(i+"HeadCode").innerHTML;
  LockerText=document.getElementById(i+"CodeText").innerHTML;
  monacoEditor.setValue("");
  SelectLanguage(LockerText);
}
function toUtf8(str) {   
    var out, i, len, c;   
    out = "";   
    len = str.length;   
    for(i = 0; i < len; i++) {   
        c = str.charCodeAt(i);   
        if ((c >= 0x0001) && (c <= 0x007F)) {   
            out += str.charAt(i);   
        } else if (c > 0x07FF) {   
            out += String.fromCharCode(0xE0 | ((c >> 12) & 0x0F));   
            out += String.fromCharCode(0x80 | ((c >>  6) & 0x3F));   
            out += String.fromCharCode(0x80 | ((c >>  0) & 0x3F));   
        } else {   
            out += String.fromCharCode(0xC0 | ((c >>  6) & 0x1F));   
            out += String.fromCharCode(0x80 | ((c >>  0) & 0x3F));   
        }   
    }   
    return out;   
}

function CallIde(Code,language)
{
require.config({ paths: { 'vs': '../node_modules/monaco-editor/min/vs' } });
require(['vs/editor/editor.main'], function () {
    // 初始化变量
    var fileCounter = 0;
    var editorArray = [];
   
    // 定义编辑器主题
        monaco.editor.defineTheme('myTheme', {
        base: 'vs-dark',
        inherit: true,
        autoIndent: true,
        rules: [{ background: '000000' }],

        // colors: { 'editor.lineHighlightBackground': 'EDF9FA' }
    });
    monaco.editor.setTheme('myTheme');
    // 新建一个编辑器
    function newEditor(container_id, code, language) {
        var model = monaco.editor.createModel(code, language);
        var editor = monaco.editor.create(document.getElementById(container_id), {
            model: model,
            fontFamily: "Arial",
            fontSize: 18
        });

        editorArray.push(editor);
        return editor;
    }
    // 新建一个 div
    function addNewEditor(Code, language) {
        var new_container = document.createElement("DIV");
        new_container.id = "container-" + fileCounter.toString(10);
        new_container.className = "container";
        document.getElementById("Root").appendChild(new_container);
        monacoEditor=newEditor(new_container.id, Code, language);
        fileCounter += 1;
    }
    addNewEditor(Code, language);
});
window.scrollTo(0, document.body.scrollHeight);
}
function PrintCode()
{
  var PostMsg = new FormData();
                PostMsg.append('type', "SaveHtmlTemplate");
                PostMsg.append('EncryptData', window.btoa(toUtf8(monacoEditor.getValue())));
                PostMsg.append('HtmlFileName',document.getElementById("HtmlFileName").value);
                PostMsg.append('HeadCode',window.btoa(toUtf8(SetHeadCode)));
                $.ajax({
                    type: "Post",
                    async: "false",
                    dataType: "text",
                    url: "(@_WebRequestUrl_@)",
                    data: PostMsg,
                    processData: false,
                    contentType: false,
                    success: function (data) {
                    GetHtmlTemplate();
                    }
                });
}
function SelectLanguage(ENCode)
{
   
    var PostMsg = new FormData();
                PostMsg.append('type', "TryConvert");
                PostMsg.append('EncryptData', ENCode);
              
                $.ajax({
                    type: "Post",
                    async: "false",
                    dataType: "text",
                    url: "(@_WebRequestUrl_@)",
                    data: PostMsg,
                    processData: false,
                    contentType: false,
                    success: function (data) {
                    document.getElementById("Root").innerHTML="";
                    CallIde(data,$("#SelectLanguage option:selected").text());
                    }
                });
}
</script>
