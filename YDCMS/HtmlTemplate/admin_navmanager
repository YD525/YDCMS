    <div id="wrapper">
        {@#code+=nav}
        <script>
            SelectNav("栏目管理");
        </script>
        <div id="page-wrapper">
            <div class="header">
                <h1 class="page-header">
                    栏目管理 <small>查看和修改栏目</small>
                </h1>
            </div>
            <div id="page-inner">



                <div class="col-md-12">
                    <!--    Context Classes  -->
                    <div class="panel panel-default">

                        <div class="panel-heading">
                            可用的模板文件
                        </div>

                        <div class="panel-body">
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>模板文件名称</th>
                                            <th>模板调用名称</th>
                                            <th>模板类型</th>
                                            <th>静态部署路径</th>
                                            <th>模板隶属类别</th>
                                            <th>样式文件路径</th>
                                        </tr>
                                    </thead>
                                    <tbody id="AllHtmlTemplate">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!--  end  Context Classes  -->
                </div>


                <div class="col-md-12">
                    <div class="panel panel-default">
                        <div class="panel-heading">
                            新建栏目
                        </div>

                        <div class="panel-body">

                            <div class="form-group input-group"><span class="input-group-addon"><i>栏目名称</i></span><input type="text" class="form-control" id="LockerColumnName"></div>
