                                richtext = richtext + "<th>Value</th>";
                                richtext = richtext + "<th>Src</th>";
                                richtext = richtext + "<th>Setting</th>";
                                richtext = richtext + "</tr>";
                                richtext = richtext + "</thead>";
                                richtext = richtext + "<tbody>";
                                for (ir = 0; ir < data[i].AllValue.length; ir++) {
                                    richtext = richtext + "<tr>";
                                    richtext = richtext + "<td>" + ir + "</td>";
                                    richtext = richtext + "<td>" + "<input type='text' value='" + data[i].AllValue[ir] + "' id='" + data[i].ID + "A" + ir + "A" + "AllValue" + "'/>" + "</td >";
                                    richtext = richtext + "<td>" + "<input type='text' value='" + data[i].AllHref[ir] + "' id='" + data[i].ID + "A" + ir + "A" + "AllHref" + "'/>" + "</td>";
