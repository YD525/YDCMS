                                richtext = richtext + "<input type='text' class='form-control' placeholder='唯一标识符' value='" + data[i].Parent + "' id='"+data[i].ID+"Parent'>"
                                richtext = richtext + "</div>"

                                richtext = richtext + "<div class='form-group input-group' style='margin:20px 0px 0px 0px;'>"
