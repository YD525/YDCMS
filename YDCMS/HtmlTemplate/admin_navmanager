                                richtext = richtext + "</div>"

                                richtext = richtext + "<div class='form-group input-group' style='margin:20px 0px 0px 0px;'>"
                                richtext = richtext + "<span class='input-group-addon'><i>默认结构体</i></span>"
                                richtext = richtext + "<input type='text' class='form-control' placeholder='默认结构体' value='" + data[i].DefCode + "' id='"+data[i].ID+"DefCode'>"
                                richtext = richtext + "</div>"

                                richtext = richtext + "</div>";
                                richtext = richtext + "</div>";
                                richtext = richtext + "</div>";
                            }
                            document.getElementById("AllLine").innerHTML += richtext;
                        }
                    }
                });

            }
