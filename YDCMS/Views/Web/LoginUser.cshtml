@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    ViewBag.Title = "LoginUser";
}
<style>
    .RegList {
        width: 70%;
        margin: 0 auto;
    }

        .RegList div {
            padding-top: 10px;
        }

            .RegList div label {
                padding-bottom: 5px;
            }


            .RegList div input {
            }
</style>


<div class="container">
    <div class="row clearfix">
        <div class="col-md-12 column">
       
            <h3>
                登录您的账户
            </h3>

            <div class="form-group">
                <label>账户</label><input type="text" class="form-control" id="userid" />
            </div>
            <div class="form-group">
                <label>密码</label><input type="password" class="form-control" id="userpassword" />
            </div>

            <div class="checkbox">
                <label><input type="checkbox" id="LoginType" />以管理员身份登录</label>
            </div> <button class="btn btn-default" onclick="QuickLogin(this)">登录</button>

        </div>
    </div>
</div>




<script>
    function QuickLogin(element) {
        var GetLoginType = "";
        if ($("#LoginType").is(':checked'))
        {
            GetLoginType = "admin";
        }
        else
        {
            GetLoginType = "user";
        }
  $.ajax({
          type: "Get",
          async: false,
          dataType: "Json",
          url: "@Html.Raw(HttpUtility.HtmlDecode(WebMaster.DataManager.DeFine.DefWebRequestUrl))",
         data: "type=LoginUser&userid=" + document.getElementById("userid").value + "&userpassword=" + document.getElementById("userpassword").value + "&logintype=" + GetLoginType +"&HrefLocker=true",
         success: function (data)
         {
             alert(data.Msg);
             window.location.href = data.targethtml;
         }
  });
    }
</script>